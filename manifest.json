{
  "manifest_version": 3,
  "name": "JARVIS Memory Sync",
  "version": "1.0",
  "description": "Sincroniza conversaciones de Claude y ChatGPT con la memoria de JARVIS",
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": [
    "https://claude.ai/*",
    "https://chatgpt.com/*",
    "https://chat.openai.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png"
    }
  },
  "content_scripts": [{
    "matches": [
      "https://claude.ai/*",
      "https://chatgpt.com/*",
      "https://chat.openai.com/*"
    ],
    "js": ["content.js"],
    "run_at": "document_idle"
  }]
}
